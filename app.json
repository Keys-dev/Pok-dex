{
  "expo": {
    "name": "reactnative1",
    "slug": "reactnative1",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/Gemini_Generated_Image_qb544lqb544lqb54.png",
    "scheme": "reactnative1",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
    "icon": "./assets/images/Gemini_Generated_Image_qb544lqb544lqb54.png",
      
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/Gemini_Generated_Image_qb544lqb544lqb54.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
